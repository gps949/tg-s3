# ===== 必填项 (仅需 3 项) =====

# Telegram Bot Token (从 @BotFather 获取)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram 群组 ID (Bot 必须是管理员, 如 -1001234567890)
DEFAULT_CHAT_ID=-1001234567890

# Cloudflare API Token
# 创建: https://dash.cloudflare.com/profile/api-tokens
# 最低权限: Workers Scripts:Edit, D1:Edit, R2:Edit, Account Settings:Read
# 如需自动创建 tunnel: 额外需要 Cloudflare Tunnel:Edit, DNS:Edit
# (本地开发可不填, 用 wrangler login 代替)
CLOUDFLARE_API_TOKEN=

# ===== 可选项 (强烈推荐) =====

# 允许使用 Bot 的 Telegram 用户 ID (逗号分隔, 如 123456789,987654321)
# 不设置则任何 Telegram 用户都可使用 Bot (不推荐)
# 获取方式: 向 @userinfobot 发送消息获取你的用户 ID
TG_ADMIN_IDS=

# ===== 可选项 =====

# Cloudflare Account ID (多账户时需要; 单账户自动检测)
# 旧名 CF_ACCOUNT_ID 仍可用但已弃用
CLOUDFLARE_ACCOUNT_ID=

# Worker 自定义域名 (留空则使用 workers.dev 子域)
# 填写后 deploy.sh 会自动创建 Cloudflare Tunnel 并配置 DNS
CF_CUSTOM_DOMAIN=

# Telegram API 凭据 (从 https://my.telegram.org 获取)
# 用于启用 Local Bot API, 将文件大小限制从 20MB 提升到 2GB
# 不填则使用公共 Bot API, 文件限制 20MB
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ===== 自动生成项 (无需手动设置) =====
# 以下变量由 deploy.sh 自动生成并写入本文件, 无需手动填写

# VPS_SECRET=             # Worker <-> Processor 共享密钥
# D1_DATABASE_ID=         # D1 数据库 ID (首次部署后自动记录)
# CF_TUNNEL_TOKEN=        # Cloudflare Tunnel Token (自动创建)
# VPS_URL=                # Processor 访问地址 (自动设为 tunnel 域名)
