# ===== 必填项 =====

# Telegram Bot Token (从 @BotFather 获取)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram 频道/群组 ID (Bot 必须是管理员, 如 -1001234567890)
DEFAULT_CHAT_ID=-1001234567890

# S3 认证凭据 (自定义, 用于 rclone/aws cli 连接)
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Bearer Token (自定义, 用于 Web UI / API 直接调用)
BEARER_TOKEN=your-bearer-token

# ===== VPS 部署 (可选, 启用大文件和媒体处理) =====

# VPS SSH 地址 (如 root@1.2.3.4)
VPS_SSH=

# VPS 上部署目录
VPS_DEPLOY_DIR=/opt/tg-s3

# VPS 处理服务端口 (VPS 本地监听)
VPS_PORT=3000

# VPS 公网访问地址 (Worker 调用, 如 https://vps.example.com:3000)
VPS_URL=

# Worker <-> VPS 共享密钥 (自定义)
VPS_SECRET=your-vps-secret

# ===== CF Worker 配置 =====

# Cloudflare API Token (Docker 部署必填, 本地部署可用 wrangler login 代替)
# 创建: https://dash.cloudflare.com/profile/api-tokens
# 需要权限: Workers Scripts:Edit, D1:Edit, R2:Edit, Account Settings:Read
CLOUDFLARE_API_TOKEN=

# Worker 自定义域名 (可选, 留空则使用 workers.dev 子域)
CF_CUSTOM_DOMAIN=

# Cloudflare Account ID (可选, 多账户时需要)
CF_ACCOUNT_ID=
